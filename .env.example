# Variáveis de ambiente para o coletor local (coletor.py)
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NUNCA deve ser commitado no repositório.

# String de conexão com o banco Railway (obtida no painel Railway > seu projeto > PostgreSQL > Connect)
DATABASE_URL=postgresql://postgres:SUA_SENHA@caboose.proxy.rlwy.net:11094/railway

# URL da API local do Input BI (valor padrão já definido no coletor caso esta variável não exista)
VENTTOS_API_URL=http://192.168.1.35:5000/api/producao
